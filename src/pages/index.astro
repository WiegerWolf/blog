---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getFeedTitle } from "../lib/postPreview";

type BlogPostModule = {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string | Date;
    lang?: "en" | "ru";
    messageCount?: number;
    previewImages?: string[];
    previewVideos?: string[];
    youtubeVideoIds?: string[];
    singleMessageHtml?: string;
  };
  url: string;
};

const postModules = [
  ...Object.values(import.meta.glob("./en/blog/*.md", { eager: true })),
  ...Object.values(import.meta.glob("./ru/blog/*.md", { eager: true }))
] as BlogPostModule[];

const posts = postModules
  .map((post) => ({
    title: getFeedTitle(post.frontmatter.title, post.frontmatter.description),
    pubDate: new Date(post.frontmatter.pubDate),
    url: post.url,
    lang: post.frontmatter.lang ?? (post.url.startsWith("/ru/") ? "ru" : "en"),
    messageCount: post.frontmatter.messageCount ?? 0,
    previewImages: (post.frontmatter.previewImages ?? []).slice(0, 4),
    previewVideos: (post.frontmatter.previewVideos ?? []).slice(0, 2),
    youtubeVideoIds: (post.frontmatter.youtubeVideoIds ?? []).slice(0, 2),
    singleMessageHtml: (post.frontmatter.singleMessageHtml ?? "").trim()
  }))
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime())
  .slice(0, 6);
---

<BaseLayout
  title="Tsatsin"
  description="Tech explorations in threads. From Telegram to web."
>
  <section class="hero">
    <p class="eyebrow">blog.tsatsin.com</p>
    <h1>Tech explorations in threads</h1>
    <p>
      Forwarded from Telegram. AI experiments, hardware hacks, and whatever I'm currently breaking.
    </p>
  </section>

  <section class="language-grid" aria-label="Language sections">
    <a class="language-card" href="/en/">
      <p class="eyebrow">English</p>
      <h2>Read in English</h2>
      <p>Posts, notes, and walkthroughs in English.</p>
    </a>

    <a class="language-card" href="/ru/">
      <p class="eyebrow">Русский</p>
      <h2>Читать по-русски</h2>
      <p>Посты и практические заметки на русском языке.</p>
    </a>
  </section>

  <section>
    <h2 class="section-title">Latest Thread Feed</h2>
    <div class="thread-list">
      {
        posts.map((post) => {
          const isQuickThread =
            post.messageCount === 1 &&
            (post.previewImages.length === 1 || post.previewVideos.length === 1 || post.youtubeVideoIds.length > 0);

          if (isQuickThread) {
            return (
              <article class="thread-item thread-item-quick">
                <p class="thread-meta">
                  <a class="thread-quick-link" href={post.url}>
                    {post.pubDate.toLocaleDateString(post.lang === "ru" ? "ru-RU" : "en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric"
                    })}
                  </a>
                  <span class="lang-badge" data-lang={post.lang}>{post.lang === "ru" ? "RU" : "EN"}</span>
                </p>
                {post.previewImages.length > 0 && (
                  <div class="thread-preview" data-count={post.previewImages.length}>
                    {post.previewImages.map((image) => (
                      <img src={image} alt="" loading="lazy" decoding="async" />
                    ))}
                  </div>
                )}
                {post.previewVideos.length > 0 && (
                  <div class="thread-video">
                    <video controls playsinline preload="metadata" src={post.previewVideos[0]}></video>
                  </div>
                )}
                {post.youtubeVideoIds.length > 0 && (
                  <div class="thread-embed">
                    <iframe
                      src={`https://www.youtube-nocookie.com/embed/${post.youtubeVideoIds[0]}`}
                      title="YouTube video"
                      loading="lazy"
                      referrerpolicy="strict-origin-when-cross-origin"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      allowfullscreen
                    ></iframe>
                  </div>
                )}
                {post.singleMessageHtml && <div class="thread-single" set:html={post.singleMessageHtml} />}
              </article>
            );
          }

          return (
            <a class="thread-item" href={post.url}>
              <p class="thread-meta">
                <span class="card-date">
                  {post.pubDate.toLocaleDateString(post.lang === "ru" ? "ru-RU" : "en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric"
                  })}
                </span>
                <span class="lang-badge" data-lang={post.lang}>{post.lang === "ru" ? "RU" : "EN"}</span>
                {post.messageCount > 1 && (
                  <span class="msg-count">{post.messageCount} {post.lang === "ru" ? "сообщ." : "msgs"}</span>
                )}
              </p>
              <h3 class="thread-main">{post.title}</h3>
              {post.previewImages.length > 0 && (
                <div class="thread-preview" data-count={post.previewImages.length}>
                  {post.previewImages.map((image) => (
                    <img src={image} alt="" loading="lazy" decoding="async" />
                  ))}
                </div>
              )}
              {post.previewImages.length === 0 && post.previewVideos.length > 0 && (
                <div class="thread-video">
                  <video controls playsinline preload="metadata" src={post.previewVideos[0]}></video>
                </div>
              )}
              <p class="thread-open">Open thread →</p>
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
