---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  lang="en"
  title="About | Tsatsin"
  description="Thread archive from Telegram."
>
  <section class="hero">
    <p class="eyebrow">About</p>
    <h1>Telegram to web</h1>
    <p>
      I write in Telegram Saved Messages, forward here.
      Threads about AI experiments, hardware, and whatever's broken now.
    </p>
  </section>

  <section class="about-grid" aria-label="What this is">
    <article class="about-panel">
      <h2>Format</h2>
      <ul>
        <li>30-40 messages per thread.</li>
        <li>Screenshots as evidence.</li>
        <li>No editing, straight to prod.</li>
      </ul>
    </article>

    <article class="about-panel">
      <h2>Topics</h2>
      <ul>
        <li>Testing AI models on real tasks.</li>
        <li>Hardware and firmware hacking.</li>
        <li>Sharing prices and pain.</li>
      </ul>
    </article>
  </section>
</BaseLayout>
