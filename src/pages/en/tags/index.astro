---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TagCloud from "../../../components/TagCloud.astro";
import { sortFeedItemsDesc, toThreadFeedItem, type ThreadModule } from "../../../lib/threadFeed";
import { buildTagBuckets } from "../../../lib/tagBuckets";

const modules = Object.values(import.meta.glob("../blog/*.md", { eager: true })) as ThreadModule[];
const posts = sortFeedItemsDesc(modules.map((module) => toThreadFeedItem(module, "en")));
const buckets = buildTagBuckets(posts);
---

<BaseLayout lang="en" title="Tags | Tsatsin" description="Browse tags across English threads.">
  <section class="about-panel">
    <h1>Tags</h1>
    <p class="search-description">Lightweight topic index for English threads.</p>
    <TagCloud buckets={buckets} tagBasePath="/en/tags" emptyLabel="No tags yet." />
  </section>
</BaseLayout>
