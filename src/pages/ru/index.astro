---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getFeedTitle } from "../../lib/postPreview";

type BlogPostModule = {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string | Date;
    messageCount?: number;
  };
  url: string;
};

const postModules = Object.values(import.meta.glob("./blog/*.md", { eager: true })) as BlogPostModule[];

const posts = postModules
  .map((post) => ({
    title: getFeedTitle(post.frontmatter.title, post.frontmatter.description),
    pubDate: new Date(post.frontmatter.pubDate),
    url: post.url,
    messageCount: post.frontmatter.messageCount ?? 0
  }))
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());
---

<BaseLayout
  lang="ru"
  title="Треды на русском | Tsatsin"
  description="Тех-эксперименты, AI и железо. Из Telegram в веб."
>
  <section>
    <h2 class="section-title">Лента тредов</h2>
    <div class="thread-list">
      {
        posts.map((post) => (
          <a class="thread-item" href={post.url}>
            <p class="thread-meta">
              <span class="card-date">
                {post.pubDate.toLocaleDateString("ru-RU", {
                  year: "numeric",
                  month: "short",
                  day: "numeric"
                })}
              </span>
              <span class="thread-dot" aria-hidden="true">•</span>
              <span>тред</span>
              {post.messageCount > 0 && (
                <span class="msg-count">{post.messageCount} msgs</span>
              )}
            </p>
            <h3 class="thread-main">{post.title}</h3>
            <p class="thread-open">Открыть тред →</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
