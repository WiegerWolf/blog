---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getFeedTitle } from "../../lib/postPreview";

type BlogPostModule = {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string | Date;
    messageCount?: number;
    previewImages?: string[];
    singleMessageHtml?: string;
  };
  url: string;
};

const postModules = Object.values(import.meta.glob("./blog/*.md", { eager: true })) as BlogPostModule[];

const posts = postModules
  .map((post) => ({
    title: getFeedTitle(post.frontmatter.title, post.frontmatter.description),
    pubDate: new Date(post.frontmatter.pubDate),
    url: post.url,
    messageCount: post.frontmatter.messageCount ?? 0,
    previewImages: (post.frontmatter.previewImages ?? []).slice(0, 4),
    singleMessageHtml: (post.frontmatter.singleMessageHtml ?? "").trim()
  }))
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());
---

<BaseLayout
  lang="ru"
  title="Треды на русском | Tsatsin"
  description="Тех-эксперименты, AI и железо. Из Telegram в веб."
>
  <section>
    <h2 class="section-title">Лента тредов</h2>
    <div class="thread-list">
      {
        posts.map((post) => {
          const isQuickThread = post.messageCount === 1 && post.previewImages.length === 1;

          return (
            <a class:list={["thread-item", isQuickThread && "thread-item-quick"]} href={post.url}>
            <p class="thread-meta">
              <span class="card-date">
                {post.pubDate.toLocaleDateString("ru-RU", {
                  year: "numeric",
                  month: "short",
                  day: "numeric"
                })}
              </span>
              {post.messageCount > 1 && (
                <span class="msg-count">{post.messageCount} сообщ.</span>
              )}
            </p>
            {
              isQuickThread && post.singleMessageHtml
                ? (
                    <>
                      {post.previewImages.length > 0 && (
                        <div class="thread-preview" data-count={post.previewImages.length}>
                          {post.previewImages.map((image) => (
                            <img src={image} alt="" loading="lazy" decoding="async" />
                          ))}
                        </div>
                      )}
                      <p class="thread-single" set:html={post.singleMessageHtml} />
                    </>
                  )
                : (
                    <>
                      <h3 class="thread-main">{post.title}</h3>
                      {post.previewImages.length > 0 && (
                        <div class="thread-preview" data-count={post.previewImages.length}>
                          {post.previewImages.map((image) => (
                            <img src={image} alt="" loading="lazy" decoding="async" />
                          ))}
                        </div>
                      )}
                    </>
                  )
            }
            {!isQuickThread && <p class="thread-open">Открыть тред →</p>}
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
