---
import BaseLayout from "./BaseLayout.astro";
import type { ThreadModule } from "../lib/threadFeed";
import { rankSimilarPosts } from "../lib/similarPosts";

interface Frontmatter {
  title: string;
  description: string;
  pubDate: string | Date;
  lang?: "en" | "ru";
  translationKey?: string;
  showHeader?: boolean;
  showDate?: boolean;
}

interface Props {
  frontmatter?: Frontmatter;
  title?: string;
  description?: string;
  pubDate?: string | Date;
  lang?: "en" | "ru";
  translationKey?: string;
  showHeader?: boolean;
  showDate?: boolean;
}

const props = Astro.props as Props;
const data = props.frontmatter ?? props;

const title = data.title ?? "Untitled";
const description = data.description ?? "";
const lang = data.lang === "ru" ? "ru" : "en";
const showHeader = data.showHeader === true;
const showDate = data.showDate !== false;
const published = data.pubDate ? new Date(data.pubDate) : new Date();
const safePublished = Number.isNaN(published.getTime()) ? new Date() : published;
const locale = lang === "ru" ? "ru-RU" : "en-US";
const dateOptions: Intl.DateTimeFormatOptions = {
  year: "numeric",
  month: "short",
  day: "numeric"
};

const publishedIso = safePublished.toISOString();
const publishedLabel = safePublished.toLocaleDateString(locale, dateOptions);

const enModules = Object.values(import.meta.glob("../pages/en/blog/*.md", { eager: true })) as ThreadModule[];
const ruModules = Object.values(import.meta.glob("../pages/ru/blog/*.md", { eager: true })) as ThreadModule[];
const sourceModules = lang === "ru" ? ruModules : enModules;

const relatedPosts = rankSimilarPosts(
  {
    title,
    description,
    pubDate: safePublished,
    url: Astro.url.pathname,
    lang
  },
  sourceModules.map((module) => ({
    title: module.frontmatter.title,
    description: module.frontmatter.description,
    pubDate: module.frontmatter.pubDate,
    url: module.url,
    lang,
    previewImage: module.frontmatter.previewImages?.[0]
  })),
  3
).map((post) => {
  const postDate = new Date(post.pubDate);
  const safePostDate = Number.isNaN(postDate.getTime()) ? safePublished : postDate;
  return {
    ...post,
    dateIso: safePostDate.toISOString(),
    dateLabel: safePostDate.toLocaleDateString(locale, dateOptions)
  };
});

const relatedAriaLabel = lang === "ru" ? "Что почитать еще" : "More to read";
---

<BaseLayout title={`${title} | Tsatsin Blog`} description={description} lang={lang}>
  <article class="post-wrap" data-pagefind-body>
    {
      showDate && (
        <p class="post-date">
          <time datetime={publishedIso}>{publishedLabel}</time>
        </p>
      )
    }
    {
      showHeader && (
        <header class="post-header">
          <h1>{title}</h1>
          <p>{description}</p>
        </header>
      )
    }
    <div class="post-prose">
      <slot />
    </div>
  </article>
  {
    relatedPosts.length > 0 && (
      <div class="post-grid post-related-grid" aria-label={relatedAriaLabel}>
        {relatedPosts.map((post) => (
          <a class="post-card post-related-item" href={post.url}>
            <p class="card-date">
              <time datetime={post.dateIso}>{post.dateLabel}</time>
            </p>
            <h3>{post.title}</h3>
            {post.previewImage && (
              <div class="post-related-media">
                <img src={post.previewImage} alt={post.title} loading="lazy" decoding="async" />
              </div>
            )}
            {post.description && <p class="post-related-description">{post.description}</p>}
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
