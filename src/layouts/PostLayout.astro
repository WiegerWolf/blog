---
import BaseLayout from "./BaseLayout.astro";

interface Frontmatter {
  title: string;
  description: string;
  pubDate: string | Date;
  lang?: "en" | "ru";
  translationKey?: string;
  showHeader?: boolean;
  showDate?: boolean;
}

interface Props {
  frontmatter?: Frontmatter;
  title?: string;
  description?: string;
  pubDate?: string | Date;
  lang?: "en" | "ru";
  translationKey?: string;
  showHeader?: boolean;
  showDate?: boolean;
}

const props = Astro.props as Props;
const data = props.frontmatter ?? props;

const title = data.title ?? "Untitled";
const description = data.description ?? "";
const lang = data.lang === "ru" ? "ru" : "en";
const showHeader = data.showHeader === true;
const showDate = data.showDate !== false;
const published = data.pubDate ? new Date(data.pubDate) : new Date();
const safePublished = Number.isNaN(published.getTime()) ? new Date() : published;
const publishedIso = safePublished.toISOString();
const publishedLabel = safePublished.toLocaleDateString(lang === "ru" ? "ru-RU" : "en-US", {
  year: "numeric",
  month: "short",
  day: "numeric"
});
---

<BaseLayout title={`${title} | Tsatsin Blog`} description={description} lang={lang}>
  <article class="post-wrap">
    {
      showDate && (
        <p class="post-date">
          <time datetime={publishedIso}>{publishedLabel}</time>
        </p>
      )
    }
    {
      showHeader && (
        <header class="post-header">
          <h1>{title}</h1>
          <p>{description}</p>
        </header>
      )
    }
    <div class="post-prose">
      <slot />
    </div>
  </article>
</BaseLayout>
