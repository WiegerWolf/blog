---
import BaseLayout from "./BaseLayout.astro";
import type { ThreadModule } from "../lib/threadFeed";
import { rankSimilarPosts } from "../lib/similarPosts";
import { buildThreadTags } from "../lib/postTags";

interface Frontmatter {
  title: string;
  description: string;
  pubDate: string | Date;
  lang?: "en" | "ru";
  messageCount?: number;
  previewImages?: string[];
  previewVideos?: string[];
  youtubeVideoIds?: string[];
  singleMessageHtml?: string;
  tags?: string[];
  translationKey?: string;
  showHeader?: boolean;
  showDate?: boolean;
  telegramPostUrl?: string;
}

interface Props {
  frontmatter?: Frontmatter;
  title?: string;
  description?: string;
  pubDate?: string | Date;
  lang?: "en" | "ru";
  messageCount?: number;
  previewImages?: string[];
  previewVideos?: string[];
  youtubeVideoIds?: string[];
  singleMessageHtml?: string;
  tags?: string[];
  translationKey?: string;
  showHeader?: boolean;
  showDate?: boolean;
  telegramPostUrl?: string;
}

const props = Astro.props as Props;
const data = props.frontmatter ?? props;

const title = data.title ?? "Untitled";
const description = data.description ?? "";
const lang = data.lang === "ru" ? "ru" : "en";
const showHeader = data.showHeader === true;
const showDate = data.showDate !== false;
const published = data.pubDate ? new Date(data.pubDate) : new Date();
const safePublished = Number.isNaN(published.getTime()) ? new Date() : published;
const locale = lang === "ru" ? "ru-RU" : "en-US";
const dateOptions: Intl.DateTimeFormatOptions = {
  year: "numeric",
  month: "short",
  day: "numeric"
};

const publishedIso = safePublished.toISOString();
const publishedLabel = safePublished.toLocaleDateString(locale, dateOptions);
const tagBasePath = lang === "ru" ? "/ru/tags" : "/en/tags";
const telegramPostUrl = typeof data.telegramPostUrl === "string" ? data.telegramPostUrl.trim() : "";
const tags = buildThreadTags({
  defaultLang: lang,
  url: Astro.url.pathname,
  title,
  description,
  lang,
  messageCount: data.messageCount,
  previewImages: data.previewImages,
  previewVideos: data.previewVideos,
  youtubeVideoIds: data.youtubeVideoIds,
  singleMessageHtml: data.singleMessageHtml,
  tags: data.tags
});

const enModules = Object.values(import.meta.glob("../pages/en/blog/*.md", { eager: true })) as ThreadModule[];
const ruModules = Object.values(import.meta.glob("../pages/ru/blog/*.md", { eager: true })) as ThreadModule[];
const sourceModules = lang === "ru" ? ruModules : enModules;

const relatedPosts = rankSimilarPosts(
  {
    title,
    description,
    pubDate: safePublished,
    url: Astro.url.pathname,
    lang
  },
  sourceModules.map((module) => ({
    title: module.frontmatter.title,
    description: module.frontmatter.description,
    pubDate: module.frontmatter.pubDate,
    url: module.url,
    lang,
    previewImage: module.frontmatter.previewImages?.[0]
  })),
  3
).map((post) => {
  const postDate = new Date(post.pubDate);
  const safePostDate = Number.isNaN(postDate.getTime()) ? safePublished : postDate;
  return {
    ...post,
    dateIso: safePostDate.toISOString(),
    dateLabel: safePostDate.toLocaleDateString(locale, dateOptions)
  };
});

const relatedAriaLabel = lang === "ru" ? "Что почитать еще" : "More to read";

const telegramDiscussionTarget = (() => {
  if (!telegramPostUrl) {
    return "";
  }

  try {
    const parsed = new URL(telegramPostUrl);
    if (parsed.hostname !== "t.me" && parsed.hostname !== "www.t.me") {
      return "";
    }

    const parts = parsed.pathname.split("/").filter(Boolean);
    if (parts.length < 2) {
      return "";
    }

    const [channel, postIdRaw] = parts;
    const postId = Number(postIdRaw);
    if (!/^[a-zA-Z0-9_]{5,}$/.test(channel) || !Number.isInteger(postId) || postId <= 0) {
      return "";
    }

    return `${channel}/${postId}`;
  } catch {
    return "";
  }
})();

const commentsHeading = lang === "ru" ? "Комментарии" : "Comments";
---

<BaseLayout title={`${title} | Tsatsin Blog`} description={description} lang={lang}>
  <article class="post-wrap" data-pagefind-body>
    {
      showDate && (
        <p class="post-date">
          <time datetime={publishedIso}>{publishedLabel}</time>
        </p>
      )
    }
    {
      showHeader && (
        <header class="post-header">
          <h1>{title}</h1>
          <p>{description}</p>
        </header>
      )
    }
    <div class="post-prose">
      <slot />
    </div>
    {
      tags.length > 0 && (
        <p class="thread-tags thread-tags-subtle post-tags" aria-label={lang === "ru" ? "Теги" : "Tags"}>
          {tags.map((tag) => (
            <a class="tag-chip" href={`${tagBasePath}/${encodeURIComponent(tag)}/`}>#{tag}</a>
          ))}
        </p>
      )
    }
    {
      telegramDiscussionTarget && (
        <section class="post-comments" aria-label={commentsHeading}>
          <h2>{commentsHeading}</h2>
          <div class="post-comments-widget">
            <script
              is:inline
              async
              src="https://telegram.org/js/telegram-widget.js?22"
              data-telegram-discussion={telegramDiscussionTarget}
              data-comments-limit="20"
            ></script>
          </div>
        </section>
      )
    }
  </article>
  {
    relatedPosts.length > 0 && (
      <div class="post-grid post-related-grid" aria-label={relatedAriaLabel}>
        {relatedPosts.map((post) => (
          <a class="post-card post-related-item" href={post.url}>
            <p class="card-date">
              <time datetime={post.dateIso}>{post.dateLabel}</time>
            </p>
            <h3>{post.title}</h3>
            {post.previewImage && (
              <div class="post-related-media">
                <img src={post.previewImage} alt={post.title} loading="lazy" decoding="async" />
              </div>
            )}
            {post.description && <p class="post-related-description">{post.description}</p>}
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
