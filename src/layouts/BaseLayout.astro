---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: "en" | "ru";
}

const {
  title,
  description = "Notes on building things with clarity.",
  image = "/og-image.svg",
  lang: providedLang
} = Astro.props as Props;

const site = Astro.site ?? new URL("https://blog.tsatsin.com");
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL(image, site).toString();

const pathParts = Astro.url.pathname.split("/").filter(Boolean);
const section = pathParts[0] === "en" || pathParts[0] === "ru" ? pathParts[0] : "root";
const lang = providedLang ?? (section === "ru" ? "ru" : "en");
const ogLocale = lang === "ru" ? "ru_RU" : "en_US";

const brandHref = section === "root" ? "/" : `/${section}/`;
const rssHref = section === "root" ? "/rss.xml" : `/${section}/rss.xml`;

const navLinks =
  section === "ru"
    ? [
        { href: "/ru/", label: "Треды" },
        { href: "/ru/about/", label: "О тредах" },
        { href: "/en/", label: "EN" },
        { href: rssHref, label: "RSS" }
      ]
    : section === "en"
      ? [
          { href: "/en/", label: "Threads" },
          { href: "/en/about/", label: "About" },
          { href: "/ru/", label: "RU" },
          { href: rssHref, label: "RSS" }
        ]
      : [
          { href: "/", label: "Threads" },
          { href: "/en/", label: "EN" },
          { href: "/ru/", label: "RU" },
          { href: rssHref, label: "RSS" }
        ];

const rssTitle =
  section === "ru" ? "Tsatsin RSS (RU)" : section === "en" ? "Tsatsin RSS (EN)" : "Tsatsin RSS";

const footerText =
  lang === "ru"
    ? `<a href="https://github.com/WiegerWolf/blog" target="_blank" rel="noopener">GitHub</a> • <a href="https://www.youtube.com/@ArtemPlays" target="_blank" rel="noopener">YouTube</a>`
    : `<a href="https://github.com/WiegerWolf/blog" target="_blank" rel="noopener">GitHub</a> • <a href="https://www.youtube.com/@ArtemPlays" target="_blank" rel="noopener">YouTube</a>`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={rssTitle} href={rssHref} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Sora:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="ambient-field" aria-hidden="true">
      <div class="ambient-blob ambient-blob-a"></div>
      <div class="ambient-blob ambient-blob-b"></div>
      <div class="ambient-blob ambient-blob-c"></div>
    </div>
    <div class="page-glow" aria-hidden="true"></div>
    <div class="page-glow page-glow-alt" aria-hidden="true"></div>
    <header class="site-shell site-header">
      <a class="brand" href={brandHref}>Tsatsin</a>
      <nav class="nav-links" aria-label="Main navigation">
        {
          navLinks.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))
        }
      </nav>
    </header>

    <main class="site-shell site-main">
      <slot />
    </main>

    <footer class="site-shell site-footer">
      <p set:html={footerText} />
    </footer>
  </body>
</html>
