---
import "../styles/global.css";
import Icon from "../components/Icon.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: "en" | "ru";
}

const {
  title,
  description = "Notes on building things with clarity.",
  image = "/og-image.svg",
  lang: providedLang
} = Astro.props as Props;

const site = Astro.site ?? new URL("https://blog.tsatsin.com");
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL(image, site).toString();

const pathParts = Astro.url.pathname.split("/").filter(Boolean);
const section: "root" | "en" | "ru" = pathParts[0] === "en" || pathParts[0] === "ru" ? pathParts[0] : "root";
const lang = providedLang ?? (section === "ru" ? "ru" : "en");
const ogLocale = lang === "ru" ? "ru_RU" : "en_US";

const brandHref = section === "root" ? "/" : `/${section}/`;
const rssHref = section === "root" ? "/rss.xml" : `/${section}/rss.xml`;

type NavKey = "threads" | "search" | "calendar" | "about";
type NavIcon = "threads" | "search" | "calendar" | "info" | "podcast" | "language" | "rss";

interface NavItem {
  href: string;
  label: string;
  icon: NavIcon;
  key?: NavKey;
}

const normalizedPath = Astro.url.pathname.replace(/\/+$/, "") || "/";

const activeNavKey: NavKey | null = (() => {
  if (section === "en" || section === "ru") {
    const prefix = `/${section}`;
    if (normalizedPath === prefix || normalizedPath.startsWith(`${prefix}/blog/`)) {
      return "threads";
    }
    if (normalizedPath === `${prefix}/search` || normalizedPath.startsWith(`${prefix}/search/`)) {
      return "search";
    }
    if (normalizedPath === `${prefix}/calendar` || normalizedPath.startsWith(`${prefix}/calendar/`)) {
      return "calendar";
    }
    if (normalizedPath === `${prefix}/about` || normalizedPath.startsWith(`${prefix}/about/`)) {
      return "about";
    }
    return null;
  }

  if (normalizedPath === "/" || normalizedPath.startsWith("/blog/")) {
    return "threads";
  }
  if (normalizedPath === "/search" || normalizedPath.startsWith("/search/")) {
    return "search";
  }
  if (normalizedPath === "/calendar" || normalizedPath.startsWith("/calendar/")) {
    return "calendar";
  }
  if (normalizedPath === "/about" || normalizedPath.startsWith("/about/")) {
    return "about";
  }
  return null;
})();

const navLinks: NavItem[] =
  section === "ru"
    ? [
        { href: "/ru/", label: "Треды", icon: "threads", key: "threads" },
        { href: "/ru/search/", label: "Поиск", icon: "search", key: "search" },
        { href: "/ru/calendar/", label: "Календарь", icon: "calendar", key: "calendar" },
        { href: "/ru/about/", label: "О тредах", icon: "info", key: "about" },
        { href: "https://artempodcast.com", label: "Подкаст", icon: "podcast" },
        { href: "/en/", label: "EN", icon: "language" },
        { href: rssHref, label: "RSS", icon: "rss" }
      ]
    : section === "en"
      ? [
          { href: "/en/", label: "Threads", icon: "threads", key: "threads" },
          { href: "/en/search/", label: "Search", icon: "search", key: "search" },
          { href: "/en/calendar/", label: "Calendar", icon: "calendar", key: "calendar" },
          { href: "/en/about/", label: "About", icon: "info", key: "about" },
          { href: "https://artempodcast.com", label: "Podcast", icon: "podcast" },
          { href: "/ru/", label: "RU", icon: "language" },
          { href: rssHref, label: "RSS", icon: "rss" }
        ]
      : [
          { href: "/", label: "Threads", icon: "threads", key: "threads" },
          { href: "/search/", label: "Search", icon: "search", key: "search" },
          { href: "/calendar/", label: "Calendar", icon: "calendar", key: "calendar" },
          { href: "https://artempodcast.com", label: "Podcast", icon: "podcast" },
          { href: "/en/", label: "EN", icon: "language" },
          { href: "/ru/", label: "RU", icon: "language" },
          { href: rssHref, label: "RSS", icon: "rss" }
        ];

const rssTitle =
  section === "ru" ? "Tsatsin RSS (RU)" : section === "en" ? "Tsatsin RSS (EN)" : "Tsatsin RSS";

const isExternalLink = (href: string) => href.startsWith("http://") || href.startsWith("https://");

const footerLinks = [
  { href: "https://github.com/WiegerWolf/blog", label: "GitHub", icon: "github" as const },
  { href: "https://www.youtube.com/@ArtemPlays", label: "YouTube", icon: "youtube" as const }
];

const mobileMenuLabel = lang === "ru" ? "Мобильное меню" : "Mobile menu";
const openMenuLabel = lang === "ru" ? "Открыть меню" : "Open menu";
const closeMenuLabel = lang === "ru" ? "Закрыть меню" : "Close menu";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="theme-color" content="#f6f7fb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c1016" media="(prefers-color-scheme: dark)" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={rssTitle} href={rssHref} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Sora:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="ambient-field" aria-hidden="true">
      <div class="ambient-blob ambient-blob-a"></div>
      <div class="ambient-blob ambient-blob-b"></div>
      <div class="ambient-blob ambient-blob-c"></div>
    </div>
    <div class="page-glow" aria-hidden="true"></div>
    <div class="page-glow page-glow-alt" aria-hidden="true"></div>
    <header class="site-shell site-header">
      <a class="brand" href={brandHref}>Tsatsin</a>
      <nav class="nav-links" aria-label="Main navigation">
        {
          navLinks.map((item) => (
            <a
              href={item.href}
              class={item.key === activeNavKey ? "is-active" : undefined}
              aria-current={item.key === activeNavKey ? "page" : undefined}
              target={isExternalLink(item.href) ? "_blank" : undefined}
              rel={isExternalLink(item.href) ? "noopener" : undefined}
            >
              <span class="nav-link-icon">
                <Icon name={item.icon} size={16} />
              </span>
              <span class="nav-link-label">{item.label}</span>
            </a>
          ))
        }
      </nav>
      <button
        class="mobile-menu-toggle"
        type="button"
        aria-label={openMenuLabel}
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
        data-mobile-menu-toggle
      >
        <Icon name="menu" size={18} />
      </button>
    </header>

    <div class="mobile-menu" data-mobile-menu hidden>
      <button class="mobile-menu-backdrop" type="button" aria-label={closeMenuLabel} data-mobile-menu-close></button>
      <nav class="site-shell mobile-menu-panel" id="mobile-menu-panel" aria-label={mobileMenuLabel}>
        <div class="mobile-menu-head">
          <a class="brand" href={brandHref}>Tsatsin</a>
          <button class="mobile-menu-close" type="button" aria-label={closeMenuLabel} data-mobile-menu-close>
            <Icon name="close" size={18} />
          </button>
        </div>
        <div class="mobile-menu-links">
          {
            navLinks.map((item) => (
              <a
                href={item.href}
                class={item.key === activeNavKey ? "is-active" : undefined}
                aria-current={item.key === activeNavKey ? "page" : undefined}
                target={isExternalLink(item.href) ? "_blank" : undefined}
                rel={isExternalLink(item.href) ? "noopener" : undefined}
              >
                <span class="nav-link-icon">
                  <Icon name={item.icon} size={16} />
                </span>
                <span class="nav-link-label">{item.label}</span>
              </a>
            ))
          }
        </div>
      </nav>
    </div>

    <main class="site-shell site-main">
      <slot />
    </main>

    <footer class="site-shell site-footer">
      <nav class="footer-links" aria-label={lang === "ru" ? "Ссылки в подвале" : "Footer links"}>
        {
          footerLinks.map((item, index) => (
            <>
              {index > 0 && <span class="footer-sep" aria-hidden="true">•</span>}
              <a class="footer-link" href={item.href} target="_blank" rel="noopener">
                <Icon name={item.icon} size={16} />
                <span>{item.label}</span>
              </a>
            </>
          ))
        }
      </nav>
    </footer>

    <div class="image-lightbox" data-image-lightbox hidden>
      <button class="image-lightbox-close" type="button" aria-label="Close image" data-lightbox-close>
        ×
      </button>
      <figure class="image-lightbox-figure" data-lightbox-backdrop="true">
        <img src="" alt="" data-lightbox-image />
        <figcaption data-lightbox-caption></figcaption>
      </figure>
    </div>

    <script is:inline>
      (() => {
        const menu = document.querySelector("[data-mobile-menu]");
        const toggle = document.querySelector("[data-mobile-menu-toggle]");

        if (menu instanceof HTMLElement && toggle instanceof HTMLButtonElement) {
          const closeControls = menu.querySelectorAll("[data-mobile-menu-close]");
          const menuLinks = menu.querySelectorAll("a");

          const closeMenu = () => {
            if (menu.hidden) {
              return;
            }

            menu.hidden = true;
            toggle.setAttribute("aria-expanded", "false");
            document.body.classList.remove("menu-open");
            toggle.focus();
          };

          const openMenu = () => {
            menu.hidden = false;
            toggle.setAttribute("aria-expanded", "true");
            document.body.classList.add("menu-open");

            const firstLink = menu.querySelector("a");
            if (firstLink instanceof HTMLElement) {
              firstLink.focus();
            }
          };

          toggle.addEventListener("click", () => {
            if (menu.hidden) {
              openMenu();
              return;
            }

            closeMenu();
          });

          closeControls.forEach((control) => {
            control.addEventListener("click", closeMenu);
          });

          menuLinks.forEach((link) => {
            link.addEventListener("click", closeMenu);
          });

          document.addEventListener("keydown", (event) => {
            if (event.key === "Escape") {
              closeMenu();
            }
          });

          const mobileQuery = window.matchMedia("(max-width: 680px)");
          mobileQuery.addEventListener("change", (event) => {
            if (!event.matches) {
              closeMenu();
            }
          });
        }

        const lightbox = document.querySelector("[data-image-lightbox]");
        if (!(lightbox instanceof HTMLElement)) {
          return;
        }

        const image = lightbox.querySelector("[data-lightbox-image]");
        const caption = lightbox.querySelector("[data-lightbox-caption]");
        const closeButton = lightbox.querySelector("[data-lightbox-close]");

        if (!(image instanceof HTMLImageElement) || !(caption instanceof HTMLElement)) {
          return;
        }

        const closeLightbox = () => {
          lightbox.hidden = true;
          image.removeAttribute("src");
          image.alt = "";
          caption.textContent = "";
          document.body.classList.remove("lightbox-open");
        };

        const openLightbox = (src, altText) => {
          image.src = src;
          image.alt = altText;
          caption.textContent = altText;
          lightbox.hidden = false;
          document.body.classList.add("lightbox-open");
        };

        closeButton?.addEventListener("click", closeLightbox);

        lightbox.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) {
            return;
          }

          if (target === lightbox || target.dataset.lightboxBackdrop === "true") {
            closeLightbox();
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && !lightbox.hidden) {
            closeLightbox();
          }
        });

        document.addEventListener(
          "click",
          (event) => {
            const target = event.target;
            if (!(target instanceof HTMLImageElement)) {
              return;
            }

            if (!target.matches(".post-prose img, .thread-preview img")) {
              return;
            }

            event.preventDefault();
            event.stopPropagation();

            openLightbox(target.currentSrc || target.src, target.alt || "");
          },
          true
        );
      })();
    </script>
  </body>
</html>
