---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: "en" | "ru";
}

const {
  title,
  description = "Notes on building things with clarity.",
  image = "/og-image.svg",
  lang: providedLang
} = Astro.props as Props;

const site = Astro.site ?? new URL("https://blog.tsatsin.com");
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL(image, site).toString();

const pathParts = Astro.url.pathname.split("/").filter(Boolean);
const section = pathParts[0] === "en" || pathParts[0] === "ru" ? pathParts[0] : "root";
const lang = providedLang ?? (section === "ru" ? "ru" : "en");
const ogLocale = lang === "ru" ? "ru_RU" : "en_US";

const brandHref = section === "root" ? "/" : `/${section}/`;
const rssHref = section === "root" ? "/rss.xml" : `/${section}/rss.xml`;

const navLinks =
  section === "ru"
    ? [
        { href: "/ru/", label: "Треды" },
        { href: "/ru/about/", label: "О тредах" },
        { href: "https://artempodcast.com", label: "Подкаст" },
        { href: "/en/", label: "EN" },
        { href: rssHref, label: "RSS" }
      ]
    : section === "en"
      ? [
          { href: "/en/", label: "Threads" },
          { href: "/en/about/", label: "About" },
          { href: "https://artempodcast.com", label: "Podcast" },
          { href: "/ru/", label: "RU" },
          { href: rssHref, label: "RSS" }
        ]
      : [
          { href: "/", label: "Threads" },
          { href: "https://artempodcast.com", label: "Podcast" },
          { href: "/en/", label: "EN" },
          { href: "/ru/", label: "RU" },
          { href: rssHref, label: "RSS" }
        ];

const rssTitle =
  section === "ru" ? "Tsatsin RSS (RU)" : section === "en" ? "Tsatsin RSS (EN)" : "Tsatsin RSS";

const isExternalLink = (href: string) => href.startsWith("http://") || href.startsWith("https://");

const footerText =
  lang === "ru"
    ? `<a href="https://artempodcast.com" target="_blank" rel="noopener">Podcast</a> • <a href="https://github.com/WiegerWolf/blog" target="_blank" rel="noopener">GitHub</a> • <a href="https://www.youtube.com/@ArtemPlays" target="_blank" rel="noopener">YouTube</a>`
    : `<a href="https://artempodcast.com" target="_blank" rel="noopener">Podcast</a> • <a href="https://github.com/WiegerWolf/blog" target="_blank" rel="noopener">GitHub</a> • <a href="https://www.youtube.com/@ArtemPlays" target="_blank" rel="noopener">YouTube</a>`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="theme-color" content="#f6f7fb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c1016" media="(prefers-color-scheme: dark)" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={rssTitle} href={rssHref} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Sora:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="ambient-field" aria-hidden="true">
      <div class="ambient-blob ambient-blob-a"></div>
      <div class="ambient-blob ambient-blob-b"></div>
      <div class="ambient-blob ambient-blob-c"></div>
    </div>
    <div class="page-glow" aria-hidden="true"></div>
    <div class="page-glow page-glow-alt" aria-hidden="true"></div>
    <header class="site-shell site-header">
      <a class="brand" href={brandHref}>Tsatsin</a>
      <nav class="nav-links" aria-label="Main navigation">
        {
          navLinks.map((item) => (
            <a
              href={item.href}
              target={isExternalLink(item.href) ? "_blank" : undefined}
              rel={isExternalLink(item.href) ? "noopener" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main class="site-shell site-main">
      <slot />
    </main>

    <nav class="site-shell mobile-nav" aria-label="Mobile navigation">
      {
        navLinks.map((item) => (
          <a
            href={item.href}
            target={isExternalLink(item.href) ? "_blank" : undefined}
            rel={isExternalLink(item.href) ? "noopener" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <footer class="site-shell site-footer">
      <p set:html={footerText} />
    </footer>

    <div class="image-lightbox" data-image-lightbox hidden>
      <button class="image-lightbox-close" type="button" aria-label="Close image" data-lightbox-close>
        ×
      </button>
      <figure class="image-lightbox-figure" data-lightbox-backdrop="true">
        <img src="" alt="" data-lightbox-image />
        <figcaption data-lightbox-caption></figcaption>
      </figure>
    </div>

    <script is:inline>
      (() => {
        const lightbox = document.querySelector("[data-image-lightbox]");
        if (!(lightbox instanceof HTMLElement)) {
          return;
        }

        const image = lightbox.querySelector("[data-lightbox-image]");
        const caption = lightbox.querySelector("[data-lightbox-caption]");
        const closeButton = lightbox.querySelector("[data-lightbox-close]");

        if (!(image instanceof HTMLImageElement) || !(caption instanceof HTMLElement)) {
          return;
        }

        const closeLightbox = () => {
          lightbox.hidden = true;
          image.removeAttribute("src");
          image.alt = "";
          caption.textContent = "";
          document.body.classList.remove("lightbox-open");
        };

        const openLightbox = (src, altText) => {
          image.src = src;
          image.alt = altText;
          caption.textContent = altText;
          lightbox.hidden = false;
          document.body.classList.add("lightbox-open");
        };

        closeButton?.addEventListener("click", closeLightbox);

        lightbox.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) {
            return;
          }

          if (target === lightbox || target.dataset.lightboxBackdrop === "true") {
            closeLightbox();
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && !lightbox.hidden) {
            closeLightbox();
          }
        });

        document.addEventListener(
          "click",
          (event) => {
            const target = event.target;
            if (!(target instanceof HTMLImageElement)) {
              return;
            }

            if (!target.matches(".post-prose img, .thread-preview img")) {
              return;
            }

            event.preventDefault();
            event.stopPropagation();

            openLightbox(target.currentSrc || target.src, target.alt || "");
          },
          true
        );
      })();
    </script>
  </body>
</html>
